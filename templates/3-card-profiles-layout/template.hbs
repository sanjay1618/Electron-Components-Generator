<div class="profile-row">
  <div class="profile-card">
    <div class="image-container"><img src="{{p1_img}}" alt="{{p1_name}}"></div>
    <div class="profile-info">
      <a href="#" class="profile-name">{{p1_name}}</a>
      <p class="profile-title">{{p1_title}}</p>
      <div class="contact-link"><span>✉</span> <a href="mailto:{{p1_email}}">{{p1_email}}</a></div>
